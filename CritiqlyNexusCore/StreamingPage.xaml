<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CritiqlyNexusCore.StreamingPage"
             Shell.NavBarIsVisible="False"
             Title="StreamingPage">

    <ContentPage.Resources>
        <DataTemplate x:Key="NormalTemplate">
            <Border 
                BackgroundColor="#F5F5F5"
                Stroke="#D4FF3E"
                StrokeThickness="5"
                StrokeShape="RoundRectangle 10"
                WidthRequest="250"
                MaximumHeightRequest="550">

                <Grid 
                    RowDefinitions="Auto,*,Auto"
                    BackgroundColor="#1C1A15">

                    <Image
                        Source="{Binding fullPosterUrl}"
                        WidthRequest="250"
                        Grid.Row="0"/>

                    <Label 
                        Text="{Binding title}"
                        TextColor="White"
                        Padding="10"
                        FontFamily="Kimberley"
                        FontSize="15"
                        MaxLines="2"
                        HorizontalOptions="Center"
                        MinimumHeightRequest="50"
                        Grid.Row="1"/>

                    <Button 
                        Text="HITELESÍTÉS"
                        FontFamily="Kimberley"
                        FontSize="20"
                        CornerRadius="0"
                        Clicked="VerifyMovie"
                        TextColor="Black"
                        BackgroundColor="#D4FF3E"
                        Grid.Row="2"
                        MinimumHeightRequest="50"
                        CommandParameter="{Binding id}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </ContentPage.Resources>

    <VerticalStackLayout>
        <HorizontalStackLayout 
            VerticalOptions="Fill" 
            BackgroundColor="#2A2720">

            <Image 
                Source="Images/critiqlyNexusCore.png"
                MaximumHeightRequest="50"
                Margin="30,30,0,0"
                VerticalOptions="Center"
                HorizontalOptions="Center" />

            <Button 
                Margin="500,20,5,0"
                Clicked="Exit"
                x:Name="exitBtn"
                BackgroundColor="OrangeRed" 
                Text="KILÉPÉS"
                FontFamily="Kimberley"
                TextColor="White"
                MinimumWidthRequest="200"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout
            BackgroundColor="#2A2720"
            Padding="0,0,0,0">

            <Label
                x:Name="StatusLabel"
                FontSize="25"
                FontFamily="Kimberley"
                TextColor="White"
                Margin="50,30,0,0" />
        </HorizontalStackLayout>

        <HorizontalStackLayout
            VerticalOptions="Fill" 
            BackgroundColor="#2A2720">

            <Button
                Text="⛝ Hitelesítésre Váró Filmek Megtekintése"
                Clicked="CheckQueue"
                x:Name="checkQueveBtn"
                FontFamily="Kimberley"
                FontSize="20"
                BackgroundColor="#D4FF3E"
                Margin="15,30,0,20" />
        </HorizontalStackLayout>

        <CollectionView 
            ItemsSource="{Binding QueryMovies}"
            ItemTemplate="{StaticResource NormalTemplate}" 
            SelectionMode="Single"
            HorizontalScrollBarVisibility="Always"
            HeightRequest="500"
            Margin="15">

            <CollectionView.ItemsLayout>
                <GridItemsLayout 
                    Orientation="Vertical" 
                    Span="4" 
                    VerticalItemSpacing="10"/>
            </CollectionView.ItemsLayout>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>