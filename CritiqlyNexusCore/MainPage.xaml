<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CritiqlyNexusCore.MainPage"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout>
        <HorizontalStackLayout 
            VerticalOptions="Fill" 
            BackgroundColor="#2A2720">
            <Image 
                Source='Images/critiqlyNexusCore.png'
                MaximumHeightRequest="50"
                Margin="30,30,0,0"
                VerticalOptions="Center"
                HorizontalOptions="Center">
            </Image>

            <Button 
            Margin="250,20,5,0"
            Clicked="GetMovies"
            x:Name="getMoviesBtn"
            BackgroundColor="#BA521A"
            Text="FILMEK LEKÉRÉSE"
            FontFamily="Kimberley"
            TextColor="White"
            MinimumWidthRequest="200"/>

            <Button 
            Margin="5,20,5,0"
            Clicked="GetRatings"
            x:Name="getRatingsBtn"
            BackgroundColor="#BA521A" 
            Text="ÉRTÉKELÉSEK LEKÉRÉSE"
            FontFamily="Kimberley"
            TextColor="White"
            MinimumWidthRequest="200"/>

            <Button 
            Margin="40,20,5,0"
            Clicked="LogOut"
            x:Name="logOutBtn"
            BackgroundColor="Red" 
            Text="KIJELENTKEZÉS"
            FontFamily="Kimberley"
            TextColor="White"
            MinimumWidthRequest="200"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout
            BackgroundColor="#2A2720"
            Padding="0,0,0,25">
            <Label
                x:Name="welcomeLabel"
                FontSize="25"
                FontFamily="Kimberley"
                TextColor="White"
                Margin="50,30,0,0"
                />
        </HorizontalStackLayout>

        <Grid
            ColumnDefinitions="Auto,Auto,Auto,Auto"
            RowDefinitions="20,50,50,50"
            HorizontalOptions="Center"
            HeightRequest="300"
            RowSpacing="10"
            ColumnSpacing="10"
            Margin="0,50,0,0">

            <Button 
                BackgroundColor="#9BB53E"
                Text="NAPI FILMEK KIVÁLASZTÁSA"
                FontFamily="Kimberley"
                TextColor="#111111"
                x:Name="selectDailyBtn"
                Opacity="0.6"
                FontSize="30"
                IsEnabled="False"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Grid.Row="0"
                Grid.RowSpan="2"/>

            <Button 
                BackgroundColor="#9BB53E"
                Text="FELKAPOTT FILMEK FRISSÍTÉSE"
                FontFamily="Kimberley"
                TextColor="#111111"
                x:Name="updateTrendingBtn"
                Opacity="0.6"
                FontSize="30"
                IsEnabled="False"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Grid.Row="2"
                Grid.RowSpan="0"/>

            <Button 
                BackgroundColor="#9BB53E"
                Text="FILMEK SZERKESZTÉSE"
                FontFamily="Kimberley"
                TextColor="#111111"
                x:Name="updateMoviesBtn"
                Opacity="0.6"
                FontSize="30"
                IsEnabled="False"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Grid.Row="3"
                Grid.RowSpan="0"/>

            <Button
                BackgroundColor="#9BB53E"
                Text="FILMEK TÖRLÉSE"
                FontFamily="Kimberley"
                TextColor="#111111"
                x:Name="deleteMoviesBtn"
                Opacity="0.6"
                FontSize="30"
                IsEnabled="False"
                Grid.Column="3"
                Grid.ColumnSpan="0"
                Grid.Row="2"
                Grid.RowSpan="0"/>

        </Grid>
        
    </VerticalStackLayout>
</ContentPage>
