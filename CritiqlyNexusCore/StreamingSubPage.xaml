<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CritiqlyNexusCore.StreamingSubPage"
             Shell.NavBarIsVisible="False"
             Title="StreamingSubPage">

    <ContentPage.Resources>
        <ControlTemplate x:Key="RadioButtonTemplate">
            <Grid>
                <Ellipse
                    WidthRequest="22"
                    HeightRequest="22"
                    Stroke="#D4FF3E"
                    StrokeThickness="3"
                    Fill="Transparent" />

                <Ellipse
                    WidthRequest="10"
                    HeightRequest="10"
                    Fill="#D4FF3E"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    IsVisible="{TemplateBinding IsChecked}" />
            </Grid>
        </ControlTemplate>
    </ContentPage.Resources>

    <VerticalStackLayout>

        <HorizontalStackLayout 
            VerticalOptions="Fill" 
            BackgroundColor="#2A2720">

            <Image 
                Source="Images/critiqlyNexusCore.png"
                MaximumHeightRequest="50"
                Margin="30,30,0,0"
                VerticalOptions="Center"
                HorizontalOptions="Center" />

            <Button 
                Margin="500,20,5,0"
                Clicked="Back"
                x:Name="backBtn"
                BackgroundColor="OrangeRed" 
                Text="VISSZA"
                FontFamily="Kimberley"
                TextColor="White"
                MinimumWidthRequest="200"/>

            <Button 
                Margin="5,20,5,0"
                Clicked="Save"
                x:Name="saveBtn"
                BackgroundColor="#D4FF3E" 
                Text="MENTÉS"
                FontFamily="Kimberley"
                TextColor="Black"
                MinimumWidthRequest="200"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout
            BackgroundColor="#2A2720">

            <Label
                x:Name="StatusLabel"
                Text="Streaming adatok hitelesítése"
                FontSize="25"
                FontFamily="Kimberley"
                TextColor="White"
                Margin="50,30,0,20" />
        </HorizontalStackLayout>

        <Grid
            Padding="50,20,50,30"
            ColumnDefinitions="300,*"
            RowDefinitions="Auto">

            <Border 
                Grid.Column="0"
                BackgroundColor="#F5F5F5"
                Stroke="#D4FF3E"
                StrokeThickness="5"
                StrokeShape="RoundRectangle 10"
                WidthRequest="250"
                MaximumHeightRequest="400">

                <Grid
                    RowDefinitions="Auto"
                    BackgroundColor="#1C1A15">

                    <Image
                        x:Name="MoviePosterImage"
                        WidthRequest="260"
                        Grid.Row="0"/>
                </Grid>
            </Border>

            <VerticalStackLayout
                Grid.Column="1"
                Margin="40,0,0,0"
                Spacing="15">

                <Label
                    x:Name="MovieTitleLabel"
                    FontSize="28"
                    FontFamily="Kimberley"
                    TextColor="#D4FF3E"
                    Margin="0,0,0,5"/>

                <Label
                    Text="Válaszd ki, hol érhető el ténylegesen a film:"
                    FontSize="22"
                    FontFamily="Kimberley"
                    TextColor="White"
                    Margin="0,0,0,10"/>

                <Border
                    BackgroundColor="#1C1A15"
                    Stroke="#D4FF3E"
                    StrokeThickness="4"
                    StrokeShape="RoundRectangle 10"
                    Padding="20">

                    <VerticalStackLayout Spacing="15">

                        <Grid ColumnDefinitions="Auto,*">
                            <RadioButton
                                x:Name="NetflixRadioButton"
                                Grid.Column="0"
                                GroupName="StreamingPlatform"
                                Value="Netflix"
                                ControlTemplate="{StaticResource RadioButtonTemplate}"
                                VerticalOptions="Center" />

                            <Label
                                x:Name="NetflixVotesLabel"
                                Grid.Column="1"
                                Text="Netflix - 0"
                                FontFamily="Kimberley"
                                FontSize="20"
                                TextColor="White"
                                VerticalOptions="Center"
                                Margin="15,0,0,0"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <RadioButton
                                x:Name="HboRadioButton"
                                Grid.Column="0"
                                GroupName="StreamingPlatform"
                                Value="Hbo"
                                ControlTemplate="{StaticResource RadioButtonTemplate}"
                                VerticalOptions="Center" />

                            <Label
                                x:Name="HboVotesLabel"
                                Grid.Column="1"
                                Text="HBO Max - 0"
                                FontFamily="Kimberley"
                                FontSize="20"
                                TextColor="White"
                                VerticalOptions="Center"
                                Margin="15,0,0,0"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <RadioButton
                                x:Name="AmazonRadioButton"
                                Grid.Column="0"
                                GroupName="StreamingPlatform"
                                Value="Amazon"
                                ControlTemplate="{StaticResource RadioButtonTemplate}"
                                VerticalOptions="Center" />

                            <Label
                                x:Name="AmazonVotesLabel"
                                Grid.Column="1"
                                Text="Amazon Prime - 0"
                                FontFamily="Kimberley"
                                FontSize="20"
                                TextColor="White"
                                VerticalOptions="Center"
                                Margin="15,0,0,0"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <RadioButton
                                x:Name="DisneyRadioButton"
                                Grid.Column="0"
                                GroupName="StreamingPlatform"
                                Value="Disney"
                                ControlTemplate="{StaticResource RadioButtonTemplate}"
                                VerticalOptions="Center" />

                            <Label
                                x:Name="DisneyVotesLabel"
                                Grid.Column="1"
                                Text="Disney+ - 0"
                                FontFamily="Kimberley"
                                FontSize="20"
                                TextColor="White"
                                VerticalOptions="Center"
                                Margin="15,0,0,0"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <RadioButton
                                x:Name="AppleRadioButton"
                                Grid.Column="0"
                                GroupName="StreamingPlatform"
                                Value="Apple"
                                ControlTemplate="{StaticResource RadioButtonTemplate}"
                                VerticalOptions="Center" />

                            <Label
                                x:Name="AppleVotesLabel"
                                Grid.Column="1"
                                Text="Apple TV+ - 0"
                                FontFamily="Kimberley"
                                FontSize="20"
                                TextColor="White"
                                VerticalOptions="Center"
                                Margin="15,0,0,0"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <Border
                    BackgroundColor="#1C1A15"
                    Stroke="#D4FF3E"
                    StrokeThickness="4"
                    StrokeShape="RoundRectangle 10">
                        <Entry
                            x:Name="StreamingLinkEntry"
                            Placeholder="Streaming platform link..?"
                            PlaceholderColor="#AAAAAA"
                            TextColor="White"
                            FontFamily="Kimberley"
                            FontSize="18"
                            BackgroundColor="#2A2720"
                            HeightRequest="50"
                            Keyboard="Url"/>
                </Border>

                <Label
                    Text="A mentés után a film hitelesítettként lesz kezelve."
                    FontSize="16"
                    FontFamily="Kimberley"
                    TextColor="White"
                    Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Grid>
    </VerticalStackLayout>
</ContentPage>